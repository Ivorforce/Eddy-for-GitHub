# Optional. Skip the first-launch device-flow prompt and use this token
# instead. Useful for headless / CI environments where no browser is
# available.
# GITHUB_TOKEN=

# Optional. Use a different OAuth Client ID (e.g. for forks running their
# own GitHub OAuth App).
# EDDY_OAUTH_CLIENT_ID=

# Optional. Default 5734.
# PORT=5734

# Required for the Ask AI triage feature.
# ANTHROPIC_API_KEY=

# Optional. Overrides the default AI model (claude-haiku-4-5).
# AI_MODEL=

# Optional. Soft daily spend cap for AI calls in USD (default 2.0).
# AI_DAILY_CAP_USD=
